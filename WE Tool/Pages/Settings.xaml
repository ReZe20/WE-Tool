<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WE_Tool.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WE_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls" xmlns:viewmodels="using:WE_Tool.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="设置" FontSize="25" VerticalAlignment="Center" Margin="30,0,0,0"/>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel  Margin="25,10,25,0">
                    
                    <TextBlock Text="启动" Margin="5,10,0,10"/>
                    <controls:SettingsCard Header="启动页面" Description="选择启动WE Tool时的显示页面">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8A1;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedValue="{x:Bind ViewModel.StartPageTag, Mode=TwoWay}" SelectedValuePath="Tag" SelectedIndex="0" MinWidth="150">
                            <ComboBoxItem Tag="Papers" Content="已安装壁纸"/>
                            <ComboBoxItem Tag="LoadPapers" Content="导入壁纸"/>
                        </ComboBox>
                    </controls:SettingsCard>

                    <TextBlock Text="页面" Margin="5,10,0,10"/>
                    <controls:SettingsExpander Header="已有壁纸页面设置" Description="设置已有壁纸页面中的具体内容">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE756;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="在壁纸图像右上角显示壁纸类型" IsChecked="{x:Bind ViewModel.ConvertTEX, Mode=TwoWay}" Margin="65,10,0,10"/>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="" IsChecked="{x:Bind ViewModel.OneFolder, Mode=TwoWay}" Margin="65,10,0,10"/>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="同时将project.json与预览图导出至输出文件夹内" IsChecked="{x:Bind ViewModel.OutProjectJSON, Mode=TwoWay}" Margin="65,10,0,10"/>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="使用项目project.json中的名称作为项目子目录的名称，而非创意工坊ID" IsChecked="{x:Bind ViewModel.UseProjectName, Mode=TwoWay}" Margin="65,10,0,10"/>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="在提取 PKG 时不将 TEX 文件转换为图像" IsChecked="{x:Bind ViewModel.DontConvertTEX, Mode=TwoWay}" Margin="65,10,0,10"/>

                            <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                            <CheckBox Content="覆盖所有已存在的文件" IsChecked="{x:Bind ViewModel.CoverAllFiles, Mode=TwoWay}" Margin="65,10,0,10"/>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <TextBlock Text="路径" Margin="5,10,0,10"/>
                    <controls:SettingsCard Description="选择壁纸导出的存放位置" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74E;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="导出目录"/>
                                <Button Style="{StaticResource SubtleButtonStyle}">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid ColumnDefinitions="*, Auto" MinWidth="300" ColumnSpacing="8">
                            <TextBox PlaceholderText="输入或选择路径" Text="{x:Bind ViewModel.DownloadPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="浏览" Command="{x:Bind ViewModel.BrowseFolderCommand}" CommandParameter="DownloadPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <controls:SettingsCard Description="选择保存创意工坊壁纸的位置" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE774;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="创意工坊壁纸路径"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.AutoDetectWorkshopPathCommand}" CommandParameter="100">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid ColumnDefinitions="*, Auto" MinWidth="300" ColumnSpacing="8">
                            <TextBox PlaceholderText="输入或选择路径" Text="{x:Bind ViewModel.WorkshopPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="浏览" Command="{x:Bind ViewModel.BrowseFolderCommand}" CommandParameter="WorkshopPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <controls:SettingsCard Description="选择壁纸编辑器的项目位置" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xEBC6;" />
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="项目路径"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.AutoDetectWorkshopPathCommand}" CommandParameter="010">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid ColumnDefinitions="*, Auto" MinWidth="300" ColumnSpacing="8">
                            <TextBox PlaceholderText="输入或选择路径" Text="{x:Bind ViewModel.ProjectPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="浏览" Command="{x:Bind ViewModel.BrowseFolderCommand}" CommandParameter="ProjectPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <controls:SettingsCard Description="用于存储创意工坊订阅信息的文件" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8A5;" />
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ACF文件路径"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.AutoDetectWorkshopPathCommand}" CommandParameter="001">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid ColumnDefinitions="*, Auto" MinWidth="300" ColumnSpacing="8">
                            <TextBox PlaceholderText="输入或选择路径" Text="{x:Bind ViewModel.AcfPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="浏览" Command="{x:Bind ViewModel.BrowseFileCommand}" CommandParameter="AcfPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <TextBlock Text="提取" Margin="5,10,0,10"/>
                    <StackPanel>
                        <controls:SettingsExpander Header="场景壁纸设置" Description="控制对 RePKG 的输入指令">
                            <controls:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE756;"/>
                            </controls:SettingsExpander.HeaderIcon>
                            <controls:SettingsExpander.Items>
                                <Grid Margin="65,10,0,10">
                                    <CheckBox Content="忽略扩展名" x:Name="IgnoreExtension" IsChecked="{x:Bind ViewModel.IgnoreExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTipService.ToolTip="不提取具有指定扩展名的文件"/>
                                    <TextBox HorizontalAlignment="Stretch" Text="{x:Bind ViewModel.IgnoreExtensionList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding ElementName=IgnoreExtension, Path=IsChecked}" Margin="125,0,20,0" ToolTipService.ToolTip="请使用英文逗号 &quot;,&quot; 做分隔符"/>
                                </Grid>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <Grid Margin="65,10,0,10">
                                    <CheckBox Content="仅提取扩展名"  x:Name="OnlyExtension" IsChecked="{x:Bind ViewModel.OnlyExtension, Mode=TwoWay}" ToolTipService.ToolTip="仅提取具有指定扩展名的文件"/>
                                    <TextBox HorizontalAlignment="Stretch" Text="{x:Bind ViewModel.OnlyExtensionList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding ElementName=OnlyExtension, Path=IsChecked}" Margin="125,0,20,0" ToolTipService.ToolTip="请使用英文逗号 &quot;,&quot; 做分隔符"/>
                                </Grid>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="将输入目录中所有 TEX 文件转换为图像" IsChecked="{x:Bind ViewModel.ConvertTEX, Mode=TwoWay}" Margin="65,10,0,10"/>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="将所有提取的文件应放入一个目录中，不用子文件夹分别存储" IsChecked="{x:Bind ViewModel.OneFolder, Mode=TwoWay}" Margin="65,10,0,10"/>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="同时将project.json与预览图导出至输出文件夹内" IsChecked="{x:Bind ViewModel.OutProjectJSON, Mode=TwoWay}" Margin="65,10,0,10"/>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="使用项目project.json中的名称作为项目子目录的名称，而非创意工坊ID" IsChecked="{x:Bind ViewModel.UseProjectName, Mode=TwoWay}" Margin="65,10,0,10"/>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="在提取 PKG 时不将 TEX 文件转换为图像" IsChecked="{x:Bind ViewModel.DontConvertTEX, Mode=TwoWay}" Margin="65,10,0,10"/>

                                <Border BorderBrush="#E0E0E0" VerticalAlignment="Stretch" BorderThickness="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <CheckBox Content="覆盖所有已存在的文件" IsChecked="{x:Bind ViewModel.CoverAllFiles, Mode=TwoWay}" Margin="65,10,0,10"/>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>
                    </StackPanel>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
