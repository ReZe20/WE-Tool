<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WE_Tool.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WE_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls" xmlns:viewmodels="using:WE_Tool.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:WE_Tool.Converters">
    <Page.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Uid="Settings" FontSize="25" VerticalAlignment="Center" Margin="30,0,0,0"/>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel  Margin="25,10,25,0">

                    <TextBlock x:Uid="Program" Margin="5,10,0,10"/>
                    <controls:SettingsCard x:Uid="Programming_Language" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xF2B7;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedValuePath="Tag"
                                  MinWidth="150" 
                                  SelectedValue="{x:Bind ViewModel.AppSettingsVM.AppLanguage, Mode=TwoWay}">
                            <ComboBoxItem Tag="en-US">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="This language is translated by machine"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="English" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="zh-CN" Content="简体中文"/>
                            <ComboBoxItem Tag="zh-TW">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="此語言由機器翻譯"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="繁體中文" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="ja-JP">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="この言語は機械翻訳によるものです"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="日本語" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="ko-KR">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="이 언어는 기계 번역되었습니다"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="한국어" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="fr-FR">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Cette langue est traduite automatiquement"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Français" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="de-DE">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Diese Sprache wurde maschinell übersetzt"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Deutsch" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="es-ES">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Este idioma se ha traducido automáticamente"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Español" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="it-IT">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Questa lingua è tradotta automaticamente"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Italiano" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="pt-BR">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Este idioma foi traduzido por máquina"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Português (Brasil)" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="ru-RU">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Этот язык переведён машинным переводом"/>
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Русский" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE946;" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="default" x:Uid="FollowSystem"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="StartPage" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8A1;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedValue="{x:Bind ViewModel.AppSettingsVM.StartPageTag, Mode=TwoWay}" SelectedValuePath="Tag" SelectedIndex="0" MinWidth="150">
                            <ComboBoxItem Tag="Papers" x:Uid="InstalledWallpapers"/>
                            <ComboBoxItem Tag="LoadPapers" x:Uid="ImportWallpapers"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Theme" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedValue="{x:Bind ViewModel.AppSettingsVM.Theme, Mode=TwoWay}" SelectedValuePath="Tag" SelectedIndex="0" MinWidth="150">
                            <ComboBoxItem Tag="Default" x:Uid="FollowSystem"/>
                            <ComboBoxItem Tag="Light" x:Uid="Light"/>
                            <ComboBoxItem Tag="Dark" x:Uid="Dark"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    
                    <TextBlock x:Uid="Page" Margin="5,10,0,10"/>
                    <controls:SettingsExpander x:Uid="PapersSetting">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8B9;"/>
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <CheckBox x:Uid="PapersSetting_BottomBarVisibility" 
                                              IsChecked="{x:Bind ViewModel.WallpaperDisplayVM.IsBottomBarOpen, Mode=TwoWay}"/>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <CheckBox x:Uid="PapersSetting_DetailTextSelectMode"
                                              IsChecked="{x:Bind ViewModel.WallpaperDisplayVM.DetailSelectionEnabled, Mode=TwoWay}"/>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Uid="PapersSetting_WallpaperAutoPlay"
                                                  IsChecked="{x:Bind ViewModel.WallpaperDisplayVM.AutoPlayGif, Mode=TwoWay}"/>
                                    </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Uid="PapersSetting_IsWallpaperEnterAnimationEnabled"
                                                  IsChecked="{x:Bind ViewModel.WallpaperDisplayVM.IsWallpaperEnterAnimationEnabled, Mode=TwoWay}"/>
                                    </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal" >
                                        <TextBlock x:Uid="PapersSetting_WallpaperIconSize" Margin="28,0,12,0" VerticalAlignment="Center"/>
                                        <ComboBox SelectedIndex="{x:Bind ViewModel.WallpaperDisplayVM.WallpaperViewIndex, Mode=TwoWay}">
                                            <ComboBoxItem Tag="0" x:Uid="PapersSetting_ComboBoxItem_SmallIcon"/>
                                            <ComboBoxItem Tag="1" x:Uid="PapersSetting_ComboBoxItem_MediumIcon"/>
                                            <ComboBoxItem Tag="2" x:Uid="PapersSetting_ComboBoxItem_LargeIcon"/>
                                        </ComboBox>
                                    </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Uid="PapersSetting_FilterResultResponseDelay" Margin="28,0,12,0" VerticalAlignment="Center"/>
                                        <NumberBox Value="{x:Bind ViewModel.WallpaperDisplayVM.FilterResultResponseDelay, Mode=TwoWay}"
                                                   SmallChange="100"
                                                   LargeChange="1000"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="0"/>
                                    </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- 提取设置 -->
                    <TextBlock x:Uid="Extract" Margin="5,10,0,10"/>
                    <StackPanel>
                        <controls:SettingsExpander x:Uid="Settings_Output" Header="输出设置" Description="对所有壁纸类型生效" Margin="0,0,0,10">
                            <controls:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xEDE1;"/>
                            </controls:SettingsExpander.HeaderIcon>
                            <controls:SettingsExpander.Items>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <StackPanel>
                                            <RadioButtons MaxColumns="3" SelectedIndex="{x:Bind ViewModel.OutputMode, Mode=TwoWay}">
                                                <RadioButtons.Header>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock x:Uid="Settings_OutputType" FontWeight="SemiBold" Margin="28,12,12,12" Style="{ThemeResource BodyLargeTextBlockStyle}"/>
                                                            <Button x:Name="OutputTypeHelpButton" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Center" Click="OutputTypeHelpButton_Click">
                                                                <FontIcon Glyph="&#xE9CE;" FontSize="12"/>
                                                            </Button>
                                                        </StackPanel>
                                                        <TeachingTip x:Name="OutputTypeTeachingTip" Title="输出类型" Subtitle="选择壁纸的输出格式。" CloseButtonContent="关闭" ActionButtonContent="继续" ActionButtonClick="TeachingTip_ActionButtonClick" CloseButtonClick="TeachingTip_CloseButtonClick"/>
                                                    </StackPanel>
                                                </RadioButtons.Header>
                                                <RadioButton x:Name="OutputTypeFirstRadio">
                                                    <RadioButton.Content>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock x:Uid="Settings_OutputType_Full" VerticalAlignment="Top"/>
                                                                <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="Red" Margin="8,0,0,0"
                                                                          Visibility="{x:Bind ViewModel.IsConflictMode, Mode=OneWay}"
                                                                          VerticalAlignment="Center">
                                                                    <ToolTipService.ToolTip>
                                                                        <ToolTip Content="全量输出与不使用子文件夹同时选中可能导致文件目录混乱，建议关闭其中一项"/>
                                                                    </ToolTipService.ToolTip>
                                                                </FontIcon>
                                                            </StackPanel>
                                                            <RadioButtons SelectedIndex="{x:Bind ViewModel.TexExportMode, Mode=TwoWay}" IsEnabled="{Binding ViewModel.OutputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=0, Mode=OneWay}" Margin="0,24,0,0">
                                                                <RadioButtons.Header>
                                                                    <TextBlock x:Uid="Settings_TexMode" Margin="28,0,12,0" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                                </RadioButtons.Header>
                                                                <RadioButton x:Uid="Settings_TexExportRaw"/>
                                                                <RadioButton x:Uid="Settings_TexExportConvert"/>
                                                                <RadioButton x:Uid="Settings_TexExportOnlyImage"/>
                                                            </RadioButtons>
                                                            <CheckBox x:Uid="Settings_CopyProject" IsChecked="{x:Bind ViewModel.OutProjectJSON, Mode=TwoWay}" IsEnabled="{Binding ViewModel.OutputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=0, Mode=OneWay}" Margin="0,12,0,0"/>
                                                        </StackPanel>
                                                    </RadioButton.Content>
                                                </RadioButton>
                                                <RadioButton x:Name="OutputTypeImageOnlyRadio" x:Uid="Settings_OutputType_ImageOnly"/>
                                                <RadioButton x:Name="OutputTypeCustomRadio">
                                                    <RadioButton.Content>
                                                        <StackPanel>
                                                            <TextBlock x:Uid="Settings_OutputType_Custom"/>
                                                            <CheckBox x:Name="IgnoreExtension" Margin="0,24,0,0" IsChecked="{x:Bind ViewModel.IgnoreExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{x:Bind ViewModel.OutputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=2, Mode=OneWay}">
                                                                <CheckBox.Content>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock x:Uid="Settings_Output_IgnoreExtText" Margin="0,4,0,0" VerticalAlignment="Top"/>
                                                                        <TextBox x:Uid="Settings_IgnoreExtList" HorizontalAlignment="Stretch" Margin="8,0,0,0" Text="{x:Bind ViewModel.IgnoreExtensionList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding ElementName=IgnoreExtension, Path=IsChecked}"/>
                                                                    </StackPanel>
                                                                </CheckBox.Content>
                                                            </CheckBox>
                                                            <CheckBox x:Name="OnlyExtension" IsChecked="{x:Bind ViewModel.OnlyExtension, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.OutputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=2, Mode=OneWay}">
                                                                <CheckBox.Content>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock x:Uid="Settings_Output_OnlyExtText" Margin="0,4,0,0" VerticalAlignment="Top"/>
                                                                        <TextBox x:Uid="Settings_OnlyExtList" HorizontalAlignment="Stretch" Text="{x:Bind ViewModel.OnlyExtensionList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding ElementName=OnlyExtension, Path=IsChecked}" Margin="8,0,0,0"/>
                                                                    </StackPanel>
                                                                </CheckBox.Content>
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </RadioButton.Content>
                                                </RadioButton>
                                            </RadioButtons>

                                        </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>

                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Uid="Settings_FolderStructure" FontWeight="SemiBold" Margin="28,12,12,12" Style="{ThemeResource BodyLargeTextBlockStyle}"/>
                                                <Button x:Name="FolderStructureHelpButton" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Center" Click="FolderStructureHelpButton_Click">
                                                    <FontIcon Glyph="&#xE9CE;" FontSize="12"/>
                                                </Button>
                                            </StackPanel>
                                            <TeachingTip x:Name="FolderStructureTeachingTip" Title="输出文件夹结构" Subtitle="控制文件的组织方式。" CloseButtonContent="关闭" ActionButtonContent="继续" ActionButtonClick="TeachingTip_ActionButtonClick" CloseButtonClick="TeachingTip_CloseButtonClick"/>
                                            <RadioButtons SelectedIndex="{x:Bind ViewModel.OneFolder, Mode=TwoWay}" MaxColumns="2">
                                                <RadioButton x:Name="FolderStructureFirstRadio">
                                                    <RadioButton.Content>
                                                        <StackPanel>
                                                            <TextBlock x:Uid="Settings_SubfolderOutput_Header"/>
                                                            <RadioButtons SelectedIndex="{x:Bind ViewModel.OverwriteMode, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.IsSubfolderModeContentEnabled, Mode=OneWay}">
                                                                <RadioButtons.Header>
                                                                    <TextBlock x:Uid="Settings_FileConflict" FontWeight="SemiBold" Margin="28,24,0,0" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                                </RadioButtons.Header>
                                                                <RadioButton x:Uid="Settings_OverwriteFiles"/>
                                                                <RadioButton x:Uid="Settings_SkipExtracted"/>
                                                            </RadioButtons>
                                                            <CheckBox x:Uid="Settings_Subfolder_ByName"
                                                                      IsChecked="{x:Bind ViewModel.UseProjectName, Mode=TwoWay}"
                                                                      IsEnabled="{x:Bind ViewModel.IsSubfolderModeContentEnabled, Mode=OneWay}" Margin="0,12,0,0"/>
                                                        </StackPanel>
                                                    </RadioButton.Content>
                                                </RadioButton>
                                                <RadioButton x:Name="FolderStructureFlatRadio">
                                                    <RadioButton.Content>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock x:Uid="Settings_FlatOutput_Header"/>
                                                                <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="Red" Margin="8,0,0,0"
                                                                          Visibility="{x:Bind ViewModel.IsConflictMode, Mode=OneWay}"
                                                                          VerticalAlignment="Center">
                                                                    <ToolTipService.ToolTip>
                                                                        <ToolTip Content="全量输出与不使用子文件夹同时选中可能导致文件目录混乱，建议关闭其中一项"/>
                                                                    </ToolTipService.ToolTip>
                                                                </FontIcon>
                                                            </StackPanel>
                                                            <RadioButtons IsEnabled="{x:Bind ViewModel.IsFlatModeContentEnabled, Mode=OneWay}" SelectedIndex="{x:Bind ViewModel.FlatFileNamingMode, Mode=TwoWay}">
                                                                <RadioButtons.Header>
                                                                    <TextBlock x:Uid="Settings_FlatFileNaming" FontWeight="SemiBold" Margin="28,24,0,0" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                                </RadioButtons.Header>
                                                                <RadioButton x:Uid="Settings_FlatOutput_KeepName"/>
                                                                <RadioButton x:Uid="Settings_FlatOutput_ByName"/>
                                                            </RadioButtons>
                                                        </StackPanel>
                                                    </RadioButton.Content>
                                                </RadioButton>
                                            </RadioButtons>
                                        </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <RadioButtons SelectedIndex="{x:Bind ViewModel.KeepSubfolderStructure, Mode=TwoWay}">
                                            <RadioButtons.Header>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="场景类壁纸" FontWeight="SemiBold" Margin="28,12,12,12" Style="{ThemeResource BodyLargeTextBlockStyle}"/>
                                                        <Button x:Name="SceneWallpaperHelpButton" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Center" Click="SceneWallpaperHelpButton_Click">
                                                            <FontIcon Glyph="&#xE9CE;" FontSize="12"/>
                                                        </Button>
                                                    </StackPanel>
                                                    <TeachingTip x:Name="SceneWallpaperTeachingTip" Title="场景类壁纸" Subtitle="选择场景壁纸的文件夹策略。" CloseButtonContent="关闭" ActionButtonContent="继续" ActionButtonClick="TeachingTip_ActionButtonClick" CloseButtonClick="TeachingTip_CloseButtonClick"/>
                                                </StackPanel>
                                            </RadioButtons.Header>
                                            <RadioButton x:Name="SceneWallpaperFirstRadio" x:Uid="Settings_KeepStructure"/>
                                            <RadioButton x:Name="SceneWallpaperFlattenRadio" x:Uid="Settings_FlattenStructure"/>
                                        </RadioButtons>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>

                        <controls:SettingsExpander x:Uid="Settings_CpuParallel" Header="性能" Description="并发提取数、进程优先级、内存控制" Margin="0,0,0,10">
                            <controls:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE950;"/>
                            </controls:SettingsExpander.HeaderIcon>
                            <controls:SettingsExpander.Items>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="28,0,0,0">
                                            <TextBlock x:Uid="Settings_MaxConcurrent" VerticalAlignment="Center"/>
                                            <NumberBox Value="{x:Bind ViewModel.MaxConcurrentExtractions, Mode=TwoWay}" Minimum="1" Maximum="{x:Bind ViewModel.MaxConcurrentMax}" SmallChange="1" LargeChange="2" SpinButtonPlacementMode="Inline" MinWidth="80"/>
                                        </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="28,0,0,0">
                                            <TextBlock x:Uid="Settings_ProcessPriority" VerticalAlignment="Center"/>
                                            <ComboBox SelectedIndex="{x:Bind ViewModel.ProcessPriority, Mode=TwoWay}" MinWidth="120">
                                                <ComboBoxItem x:Uid="Settings_PriorityNormal"/>
                                                <ComboBoxItem x:Uid="Settings_PriorityBelowNormal"/>
                                                <ComboBoxItem x:Uid="Settings_PriorityIdle"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>
                                <controls:SettingsCard>
                                    <controls:SettingsCard.Header>
                                        <CheckBox x:Uid="Settings_LazyLoad" IsChecked="{x:Bind ViewModel.LazyLoad, Mode=TwoWay}"/>
                                    </controls:SettingsCard.Header>
                                </controls:SettingsCard>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>
                    </StackPanel>

                    <TextBlock x:Uid="Path" Margin="5,10,0,10"/>
                    <controls:SettingsCard x:Uid="ChooseWallpaperExportPath" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74E;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Uid="ExportDirectory"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" 
                                        Command="{x:Bind ViewModel.PathManagementVM.AutoDetectDownloadPathCommand}"
                                        x:Uid="AutoDetect_DownloadPath">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid MinWidth="300" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Uid="PapersBottomTextBox" Text="{x:Bind ViewModel.PathManagementVM.DownloadPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Uid="SelectFolder" Command="{x:Bind ViewModel.PathManagementVM.BrowseFolderCommand}" CommandParameter="DownloadPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="ChooseWorkshopPath" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE774;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Uid="WorkShopPath"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PathManagementVM.AutoDetectWorkshopPathCommand}" CommandParameter="1000"
                                        x:Uid="AutoDetect_WorkshopPath">
                                    <Button.Content>
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard.Header>
                        <Grid MinWidth="300" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Uid="PapersBottomTextBox" Text="{x:Bind ViewModel.PathManagementVM.WorkshopPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="WallpapersPath_TextChanged" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Uid="SelectFolder" Command="{x:Bind ViewModel.PathManagementVM.BrowseFolderCommand}" CommandParameter="WorkshopPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="ChooseProjectPath" Margin="0,0,0,10">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xEBC6;" />
                        </controls:SettingsCard.HeaderIcon>
                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Uid="ProjectPath"/>
                                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PathManagementVM.AutoDetectWorkshopPathCommand}" CommandParameter="0100"
