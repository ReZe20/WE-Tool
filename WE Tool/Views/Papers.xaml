<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WE_Tool.Papers"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WE_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WE_Tool.Models"
    xmlns:loc="using:WE_Tool.Helper"
    xmlns:converters="using:WE_Tool.Converters"
    mc:Ignorable="d"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    x:Name="PageRoot"
    NavigationCacheMode="Enabled">
    <Page.Resources>
        <converters:FileSizeToString x:Key="FileSizeToString"/>
        <converters:TypeToDisplay x:Key="TypeToDisplay"/>
        <converters:SourceToDisplay x:Key="SourceToDisplay"/>
        <converters:RatingToDisplay x:Key="RatingToDisplay"/>
        <converters:TagToDisplay x:Key="TagToDisplay"/>
        <converters:DescriptionToDisplay x:Key="DescriptionToDisplay"/>
        <converters:PapersTagContentChoose x:Key="PapersTagContentChoose"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <CommandBarFlyout x:Name="WallpaperContextMenu" AlwaysExpanded="True">
            <CommandBarFlyout.PrimaryCommands>
                <AppBarButton x:Uid="AppBarButton_Extract">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72D;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton x:Uid="AppBarButton_OpenDirectory"
                              Command="{x:Bind OpenSelectedFoldersCommand}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE838;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton x:Uid="AppBarButton_Delete" 
                              Command="{x:Bind DeleteSelectedCommand}"
                              CommandParameter="{Binding}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBarFlyout.PrimaryCommands>
            <CommandBarFlyout.SecondaryCommands>
                <AppBarButton x:Uid="AppBarButton_Copy" 
                              Click="Copy_Click_ByCommandBarFlyout"
                              KeyboardAcceleratorTextOverride="     Ctrl+C">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarButton_Cut" 
                              Click="Cut_Click_ByCommandBarFlyout"
                              KeyboardAcceleratorTextOverride="     Ctrl+V">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C6;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarButton_Delete" 
                              Command="{x:Bind DeleteSelectedCommand}"
                              KeyboardAcceleratorTextOverride="     Delete">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarButton_DeleteForever"
                              Command="{x:Bind DeleteSelectedCommand}"
                              KeyboardAcceleratorTextOverride="Shift+Del">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE75C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton x:Uid="AppBarButton_SelectAll" 
                              Click="SelectAllWallpapers_Click_ByCommandBarFlyout"
                              KeyboardAcceleratorTextOverride="     Ctrl+A">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8B3;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="AppBarButton_InvertSelection" 
                              Click="InvertSelection_CLick_ByCommandBarFlyout"
                              KeyboardAcceleratorTextOverride="     Ctrl+I">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8E6;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton x:Uid="AppBarButton_Properties" 
                              KeyboardAcceleratorTextOverride="Alt+Enter">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE90F;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBarFlyout.SecondaryCommands>
        </CommandBarFlyout>
        
        <MenuFlyout x:Name="ScrollViewBackgroundMenu">
            <MenuFlyoutItem x:Uid="MenuFlyoutItem_Refresh" 
                            Click="WallpaperListRefresh_Click_ByCommandBarFlyout"
                            KeyboardAcceleratorTextOverride="    F5">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE777;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem x:Uid="MenuFlyoutItem_SelectAll" 
                            Click="SelectAllWallpapers_Click_ByCommandBarFlyout"
                            KeyboardAcceleratorTextOverride="    Ctrl+A">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8B3;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem x:Uid="MenuFlyoutItem_InvertSelection"
                            Click="InvertSelection_CLick_ByCommandBarFlyout"
                            KeyboardAcceleratorTextOverride="    Ctrl+I">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8E6;"/>
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator/>
            <MenuFlyoutSubItem x:Uid="MenuFlyoutSubItem_View">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE890;"/>
                </MenuFlyoutSubItem.Icon>
                <RadioMenuFlyoutItem x:Uid="AppBarButton_SmallIcon" 
                                     Tag="Small"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SmallIconItem,Mode=TwoWay}"
                                     GroupName="MenuViewGroup"/>
                <RadioMenuFlyoutItem x:Uid="AppBarButton_MediumIcon"
                                     Tag="Medium"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.MediumIconItem,Mode=TwoWay}"
                                     GroupName="MenuViewGroup"/>
                <RadioMenuFlyoutItem x:Uid="AppBarButton_LargeIcon"
                                     Tag="Large"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.LargeIconItem,Mode=TwoWay}"
                                     GroupName="MenuViewGroup"/>
                    <MenuFlyoutSeparator/>
                <ToggleMenuFlyoutItem x:Uid="AppBarButton_IsAnnotatedScrollBarEnabled"
                                     IsChecked="{x:Bind ViewModel.PapersControl.IsAnnotatedScrollBarEnabled,Mode=TwoWay}"
                                     Click="ChangeAnnotatedScrollBarEnabled"/>
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem x:Uid="MenuFlyoutSubItem_TagDisplay">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE8EC;"/>
                </MenuFlyoutSubItem.Icon>
                <RadioMenuFlyoutItem GroupName="MenuLabelGroup"
                                     x:Uid="AppBarButton_Type"
                                     Click="OnTagDisplayChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.TypeDisplayInTag, Mode=TwoWay}"/>
                <RadioMenuFlyoutItem GroupName="MenuLabelGroup"
                                     x:Uid="AppBarButton_Rating"
                                     Click="OnTagDisplayChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.RatingDisplayInTag, Mode=TwoWay}"/>
                <RadioMenuFlyoutItem GroupName="MenuLabelGroup"
                                     x:Uid="AppBarButton_Source"
                                     Click="OnTagDisplayChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SourceDisplayInTag, Mode=TwoWay}"/>
                <RadioMenuFlyoutItem GroupName="MenuLabelGroup"
                                     x:Uid="AppBarButton_Tag"
                                     Click="OnTagDisplayChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.TagDisplayInTag, Mode=TwoWay}"/>
                <RadioMenuFlyoutItem GroupName="MenuLabelGroup"
                                     x:Uid="AppBarButton_None"
                                     Click="OnTagDisplayChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.NoneDisplayInTag, Mode=TwoWay}"/>
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem x:Uid="MenuFlyoutSubItem_Sort">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE8CB;"/>
                </MenuFlyoutSubItem.Icon>
                <RadioMenuFlyoutItem x:Uid="SortByName" 
                                     x:Name="SortByNameItem"
                                     Tag="Small"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SortByName,Mode=TwoWay}"
                                     GroupName="MenuSortGroup"/>
                <RadioMenuFlyoutItem x:Uid="SortBySubTime"
                                     x:Name="SortBySubTimeItem"
                                     Tag="Medium"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SortBySubTime,Mode=TwoWay}"
                                     GroupName="MenuSortGroup"/>
                <RadioMenuFlyoutItem x:Uid="SortByLastTime"
                                     x:Name="SortByLastTime"
                                     Tag="Large"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SortByLastTime,Mode=TwoWay}"
                                     GroupName="MenuSortGroup"/>
                <RadioMenuFlyoutItem x:Uid="SortByFileSize"
                                     x:Name="SortByFileSizeItem"
                                     Tag="Large"
                                     Click="OnIconSizeChanged"
                                     IsChecked="{x:Bind ViewModel.PapersControl.SortByFileSize,Mode=TwoWay}"
                                     GroupName="MenuSortGroup"/>
            </MenuFlyoutSubItem>
        </MenuFlyout>
    </Page.Resources>
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator />
        <KeyboardAccelerator Key="A" 
                             Modifiers="Control"
                             Invoked="SelectAllWallpaper_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="I" 
                             Modifiers="Control"
                             Invoked="InvertSelection_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="Enter" 
                             Modifiers="Menu"
                             Invoked="Property_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="C" 
                             Modifiers="Control"
                             Invoked="Copy_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="X" 
                             Modifiers="Control"
                             Invoked="Cut_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="Delete"
                             Modifiers="None"
                             Invoked="Delete_Accelerator_Invoked"/>
        <KeyboardAccelerator Key="Delete"
                             Modifiers="Shift"
                             Invoked="DeleteForever_Accelerator_Invoked"/>
    </Page.KeyboardAccelerators>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{x:Bind ViewModel.PapersControl.BottomBarHeight, Mode=OneWay}"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="1" Fill="{ThemeResource DividerStrokeColorDefault}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <AutoSuggestBox Grid.Row="0" 
                            Height="34"
                            Width="208" 
                            QueryIcon="Find"
                            x:Uid="SearchBox"
                            HorizontalAlignment="Left"
                            Margin="3,0,0,0" 
                            FontSize="16" 
                            CornerRadius="6"
                            FontWeight="Light"
                            VerticalAlignment="Center"
                            TextChanged="WallpaperSearchBox_TextChanged"/>
            <ToggleButton x:Name="LeftToggleFilterButton" Height="35" HorizontalAlignment="Left" BorderThickness="0" Background="Transparent" IsChecked="{x:Bind ViewModel.PapersControl.LeftSplitViewPaneOpen, Mode=TwoWay}" Margin="3,0,0,0">
                <ToggleButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE71D;" Margin="0,0,5,0" FontSize="16"/>
                        <TextBlock x:Uid="FilterResults"/>
                    </StackPanel>
                </ToggleButton.Content>
            </ToggleButton>
            <AppBarSeparator/>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.PapersControl.IsButtonInGridColumnEnabled, Mode=OneWay}">
                <Button.Content>
                    <FontIcon Glyph="&#xE8C6;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.PapersControl.IsButtonInGridColumnEnabled, Mode=OneWay}">
                <Button.Content>
                    <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.PapersControl.IsButtonInGridColumnEnabled, Mode=OneWay}"
                    Command="{x:Bind DeleteSelectedCommand}">
                <Button.Content>
                    <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.PapersControl.IsButtonInGridColumnEnabled, Mode=OneWay}"
                    Command="{x:Bind DeleteSelectedCommand}">
                <Button.Content>
                    <FontIcon Glyph="&#xE75C;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    Click="SelectAllWallpapers_Click_ByCommandBarFlyout">
                <Button.Content>
                    <FontIcon Glyph="&#xE8B3;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    Click="InvertSelection_CLick_ByCommandBarFlyout">
                <Button.Content>
                    <FontIcon Glyph="&#xE8E6;" FontSize="16"/>
                </Button.Content>
            </Button>
            <Button Style="{ThemeResource SubtleButtonStyle}"
                    Click="WallpaperListRefresh_Click_ByCommandBarFlyout">
                <Button.Content>
                    <FontIcon Glyph="&#xE777;" FontSize="16"/>
                </Button.Content>
            </Button>
            <AppBarSeparator/>
            <DropDownButton Height="35" Margin="0,0,0,0" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" BorderThickness="0" Background="Transparent">
                <DropDownButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE890;" Margin="0,0,8,0" FontSize="16"/>
                        <TextBlock x:Uid="MenuFlyoutSubItem_View"/>
                    </StackPanel>
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <RadioMenuFlyoutItem x:Uid="AppBarButton_SmallIcon" 
                                             Tag="Small"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SmallIconItem,Mode=TwoWay}"
                                             GroupName="ViewGroup"/>
                        <RadioMenuFlyoutItem x:Uid="AppBarButton_MediumIcon"
                                             Tag="Medium"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.MediumIconItem,Mode=TwoWay}"
                                             GroupName="ViewGroup"/>
                        <RadioMenuFlyoutItem x:Uid="AppBarButton_LargeIcon"
                                             Tag="Large"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.LargeIconItem,Mode=TwoWay}"
                                             GroupName="ViewGroup"/>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Uid="AppBarButton_IsAnnotatedScrollBarEnabled"
                                             IsChecked="{x:Bind ViewModel.PapersControl.IsAnnotatedScrollBarEnabled,Mode=TwoWay}"
                                             Click="ChangeAnnotatedScrollBarEnabled"/>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <DropDownButton Height="35" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" BorderThickness="0" Background="Transparent">
                <DropDownButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE8EC;" Margin="0,0,8,0" FontSize="16"/>
                        <TextBlock x:Uid="MenuFlyoutSubItem_TagDisplay"/>
                    </StackPanel>
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <RadioMenuFlyoutItem GroupName="LabelGroup"
                                             x:Uid="AppBarButton_Type"
                                             Click="OnTagDisplayChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.TypeDisplayInTag, Mode=TwoWay}"/>
                        <RadioMenuFlyoutItem GroupName="LabelGroup"
                                             x:Uid="AppBarButton_Rating"
                                             Click="OnTagDisplayChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.RatingDisplayInTag, Mode=TwoWay}"/>
                        <RadioMenuFlyoutItem GroupName="LabelGroup"
                                             x:Uid="AppBarButton_Source"
                                             Click="OnTagDisplayChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SourceDisplayInTag, Mode=TwoWay}"/>
                        <RadioMenuFlyoutItem GroupName="LabelGroup"
                                             x:Uid="AppBarButton_Tag"
                                             Click="OnTagDisplayChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.TagDisplayInTag, Mode=TwoWay}"/>
                        <RadioMenuFlyoutItem GroupName="LabelGroup"
                                             x:Uid="AppBarButton_None"
                                             Click="OnTagDisplayChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.NoneDisplayInTag, Mode=TwoWay}"/>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <DropDownButton Width="115" Height="35" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" BorderThickness="0" Style="{ThemeResource SubtleButtonStyle}">
                <DropDownButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon x:Name="sortButtonIcon" Glyph="{x:Bind ViewModel.PapersControl.SortGlyph, Mode=OneWay}" FontSize="16"/>
                        <TextBlock x:Name="sortButtonText" Text="{x:Bind ViewModel.PapersControl.SortText, Mode=OneWay}" Margin="5,0,0,0" />
                    </StackPanel>
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <RadioMenuFlyoutItem x:Uid="SortByName" 
                                             Tag="Small"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SortByName,Mode=TwoWay}"
                                             GroupName="MSortGroup"/>
                        <RadioMenuFlyoutItem x:Uid="SortBySubTime"
                                             Tag="Medium"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SortBySubTime,Mode=TwoWay}"
                                             GroupName="SortGroup"/>
                        <RadioMenuFlyoutItem x:Uid="SortByLastTime"
                                             Tag="Large"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SortByLastTime,Mode=TwoWay}"
                                             GroupName="SortGroup"/>
                        <RadioMenuFlyoutItem x:Uid="SortByFileSize"
                                             Tag="Large"
                                             Click="OnIconSizeChanged"
                                             IsChecked="{x:Bind ViewModel.PapersControl.SortByFileSize,Mode=TwoWay}"
                                             GroupName="SortGroup"/>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <ToggleButton Grid.Row="0" Height="35" Grid.Column="1" HorizontalAlignment="Right" IsChecked="{x:Bind ViewModel.PapersControl.IsSortAscending, Mode=TwoWay}" BorderThickness="0" Background="Transparent">
                <ToggleButton.Content>
                    <FontIcon x:Name="btnSortDirectionIcon" Glyph="{x:Bind ViewModel.PapersControl.SortDirectionGlyph, Mode=OneWay}" FontSize="16"/>
                </ToggleButton.Content>
            </ToggleButton>
        </StackPanel>

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,0,3,0">
            <ToggleButton x:Name="RightToggleFilterButton"
                          Grid.Row="0"
                          HorizontalAlignment="Right"
                          Width="118"
                          BorderThickness="0"
                          Background="Transparent"
                          IsChecked="{x:Bind ViewModel.PapersControl.RightSplitViewPaneOpen, Mode=TwoWay}">
                <ToggleButton.Content>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE90D;" Margin="0,0,5,0"/>
                        <TextBlock x:Uid="DetailsPanel" Margin="5,0,5,0"/>
                    </StackPanel>
                </ToggleButton.Content>
            </ToggleButton>
        </StackPanel>
        <SplitView 
                x:Name="RightSplitView" 
                PanePlacement="Right" 
                OpenPaneLength="304" 
                DisplayMode="Inline"
                Grid.Row="1"
                IsPaneOpen="{x:Bind ViewModel.PapersControl.RightSplitViewPaneOpen, Mode=TwoWay}">
            <SplitView.Pane>
                <ScrollViewer>
                    <Grid Padding="15,15,15,15" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                        <StackPanel Spacing="15">

                            <Grid x:Name="PreviewImageContainer" Height="250" Width="250" HorizontalAlignment="Center">
                                <Border x:Name="SinglePreviewBorder" Width="250" Height="250" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Image x:Name="SinglePreviewImage" Source="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Preview, Mode=OneWay, FallbackValue=null}" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="ImageScale" />
                                        </Image.RenderTransform>
                                    </Image>
                                </Border>

                                <ItemsControl x:Name="StackedImagesControl" ItemsSource="{x:Bind DisplayedSelectedWallpapers}" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Grid/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:WallpaperItem">
                                            <Border Height="150" Width="150" CornerRadius="8" Loaded="StackedImage_Loaded" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{x:Bind Preview}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <StackPanel x:Name="SingleSelectionInfoPanel" Spacing="15">
                                <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Title, Mode=OneWay, FallbackValue=''}" 
                                           IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}" 
                                           Style="{StaticResource TitleTextBlockStyle}" 
                                           TextWrapping="Wrap"
                                           FontSize="20"
                                           Margin="10,0,0,0"/>
                                <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.FolderPath, Mode=OneWay, FallbackValue=''}" 
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="Gray" 
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"
                                           Margin="10,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.FileSize, Mode=OneWay, Converter={StaticResource FileSizeToString}, FallbackValue=''}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,4,0"
                                               IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Source, Mode=OneWay, Converter={StaticResource SourceToDisplay}, FallbackValue=''}" 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               FontWeight="SemiBold"
                                               Margin="4,0,4,0"
                                               IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Type, Mode=OneWay, Converter={StaticResource TypeToDisplay}, FallbackValue=''}"
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               FontWeight="SemiBold"
                                               Margin="4,0,4,0"
                                               IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.ContentRating, Mode=OneWay, Converter={StaticResource RatingToDisplay}, FallbackValue=''}" 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               FontWeight="SemiBold"
                                               Margin="4,0,4,0"
                                               IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"/>
                                </StackPanel>
                                <Grid>
                                    <Border Background="#20808080" 
                                            CornerRadius="4" 
                                            Padding="6,2" 
                                            Margin="10,4,4,0" 
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Tags, FallbackValue=Collapsed, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Tags, Mode=OneWay, FallbackValue={x:Null}, Converter={StaticResource TagToDisplay}}" FontSize="12"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{x:Bind ViewModel.PapersControl.SelectedWallpaper.Description, FallbackValue='', Mode=OneWay, Converter={StaticResource DescriptionToDisplay}}" 
                                           Style="{StaticResource BodyTextBlockStyle}" 
                                           TextWrapping="Wrap"
                                           MaxHeight="150"
                                           TextTrimming="CharacterEllipsis"
                                           IsTextSelectionEnabled="{x:Bind ViewModel.PapersControl.DetailSelectionEnabled, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel x:Name="MultiSelectionInfoPanel" Spacing="10" Visibility="Collapsed" HorizontalAlignment="Stretch">
                                <TextBlock x:Name="MultiSelectCountText" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Grid>
                                    <Button Content="全选" Click="SelectAllWallpapers_Click" Width="130" Margin="0,0,4,0" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="反选" Click="InvertSelection_CLick" Width="130" Margin="14,0,0,0" HorizontalAlignment="Right" />
                                </Grid>
                                <Button Content="取消多选" Click="CancelMultiSelect_Click" HorizontalAlignment="Stretch" Style="{StaticResource DefaultButtonStyle}"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </SplitView.Pane>
            <SplitView.Content>
                <Grid>
                    <SplitView x:Name="LeftSplitView" PanePlacement="Left" OpenPaneLength="210" DisplayMode="Inline" IsPaneOpen="{x:Bind ViewModel.PapersControl.LeftSplitViewPaneOpen, Mode=TwoWay}">
                        <SplitView.Pane>
                            <Grid BorderBrush="#E0E0E0" BorderThickness="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Padding="15,0,15,10">
                                        <Button Margin="0,10,0,5" HorizontalAlignment="Stretch" Click="ResetFilter_Click" Style="{StaticResource AccentButtonStyle}" Grid.Row="0">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <FontIcon Glyph="&#xE895;" Margin="10,0,10,0"/>
                                                    <TextBlock x:Uid="ResetFilters"/>
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Expander x:Uid="Type" x:Name="TypeExpander" HorizontalAlignment="Stretch" Margin="0,4,0,4" IsExpanded="{x:Bind ViewModel.Types.TypeExpander, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel x:Name="TypeFilterPanel">
                                                <CheckBox x:Uid="Type_Scene" Tag="Scene" IsChecked="{x:Bind ViewModel.Types.Scene, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Type_Video" Tag="Video" IsChecked="{x:Bind ViewModel.Types.Video, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Type_Web" Tag="Web" IsChecked="{x:Bind ViewModel.Types.Web, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Type_Application" Tag="Application" IsChecked="{x:Bind ViewModel.Types.Application, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Type_Preset" Tag="Preset" IsChecked="{x:Bind ViewModel.Types.Preset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Type_Unknown" Tag="Unknow" IsChecked="{x:Bind ViewModel.Types.Unknown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Expander>

                                        <Expander x:Uid="Rating" x:Name="AgeExpander" HorizontalAlignment="Stretch" Margin="0,4,0,4" IsExpanded="{x:Bind ViewModel.Rating.RatingExpander, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel x:Name="AgeRatingFilterPanel">
                                                <CheckBox x:Uid="Rating_Everyone" Tag="G" IsChecked="{x:Bind ViewModel.Rating.G, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Rating_Questionable" Tag="PG" IsChecked="{x:Bind ViewModel.Rating.Pg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Rating_Mature" Tag="R" IsChecked="{x:Bind ViewModel.Rating.R, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Expander>

                                        <Expander x:Uid="Source" x:Name="SourceExpander" HorizontalAlignment="Stretch" Margin="0,4,0,4" IsExpanded="{x:Bind ViewModel.Source.SourceExpander, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel x:Name="SourceFilterPanel">
                                                <CheckBox x:Uid="Source_Official" Tag="Official" IsChecked="{x:Bind ViewModel.Source.Official, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Source_Workshop" Tag="Workshop" IsChecked="{x:Bind ViewModel.Source.Workshop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Source_Mine" Tag="Mine" IsChecked="{x:Bind ViewModel.Source.Mine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Expander>

                                        <Expander x:Uid="Tag" x:Name="TagsExpander" HorizontalAlignment="Stretch" Margin="0,4,0,4" IsExpanded="{x:Bind ViewModel.Tags.TagsExpander, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <StackPanel x:Name="TagsContainer">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Uid="All" Click="SelectAllTags_Click" HorizontalAlignment="Stretch" Grid.Column="0"/>
                                                    <Button x:Uid="None" Click="DeselectAllTags_Click" HorizontalAlignment="Stretch" Grid.Column="1"/>
                                                </Grid>
                                                <CheckBox x:Uid="Tag_Abstract" Tag="Abstract" IsChecked="{x:Bind ViewModel.Tags.Abstract, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Animal" Tag="Animal" IsChecked="{x:Bind ViewModel.Tags.Animal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <CheckBox x:Uid="Tag_Anime" Tag="Anime" IsChecked="{x:Bind ViewModel.Tags.Anime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Cartoon" Tag="Cartoon" IsChecked="{x:Bind ViewModel.Tags.Cartoon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_CGI" Tag="CGI" IsChecked="{x:Bind ViewModel.Tags.Cgi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Cyberpunk" Tag="Cyberpunk" IsChecked="{x:Bind ViewModel.Tags.Cyberpunk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Fantasy" Tag="Fantasy" IsChecked="{x:Bind ViewModel.Tags.Fantasy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Game" Tag="Game" IsChecked="{x:Bind ViewModel.Tags.Game, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Girls" Tag="Girls" IsChecked="{x:Bind ViewModel.Tags.Girls, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Guys" Tag="Guys" IsChecked="{x:Bind ViewModel.Tags.Guys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Landscape" Tag="Landscape" IsChecked="{x:Bind ViewModel.Tags.Landscape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Medieval" Tag="Medieval" IsChecked="{x:Bind ViewModel.Tags.Medieval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Memes" Tag="Memes" IsChecked="{x:Bind ViewModel.Tags.Memes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_MMD" Tag="MMD" IsChecked="{x:Bind ViewModel.Tags.Mmd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Music" Tag="Music" IsChecked="{x:Bind ViewModel.Tags.Music, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Nature" Tag="Nature" IsChecked="{x:Bind ViewModel.Tags.Nature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Pixelart" Tag="Pixelart" IsChecked="{x:Bind ViewModel.Tags.Pixelart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Relaxing" Tag="Relaxing" IsChecked="{x:Bind ViewModel.Tags.Relaxing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Retro" Tag="Retro" IsChecked="{x:Bind ViewModel.Tags.Retro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_SciFi" Tag="SciFi" IsChecked="{x:Bind ViewModel.Tags.SciFi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Sports" Tag="Sports" IsChecked="{x:Bind ViewModel.Tags.Sports, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Technology" Tag="Technology" IsChecked="{x:Bind ViewModel.Tags.Technology, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Television" Tag="Television" IsChecked="{x:Bind ViewModel.Tags.Television, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Vehicle" Tag="Vehicle" IsChecked="{x:Bind ViewModel.Tags.Vehicle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox x:Uid="Tag_Unspecified" Tag="Unspecified" IsChecked="{x:Bind ViewModel.Tags.Unspecified, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </SplitView.Pane>

                        <SplitView.Content>
                            <Grid>
                                <ScrollView HorizontalAnchorRatio="0.5" 
                                            VerticalAnchorRatio="0.5"
                                            x:Name="WallpapersScrollView"
                                            VerticalScrollBarVisibility="{x:Bind ViewModel.PapersControl.PapersScrollViewBarVisibility,Mode=OneWay}"
                                            Grid.Column="0"
                                            ContextFlyout="{StaticResource ScrollViewBackgroundMenu}"
                                            Tapped="WallpaperList_Tapped">
                                    <StackPanel Margin="{x:Bind ViewModel.PapersControl.PapersScrollViewMargin, Mode=OneWay}">
                                        <StackPanel x:Name="NoResultTip" Visibility="Collapsed" Margin="0,100,0,0">
                                            <TextBlock x:Uid="NoResultTip1"
                                                   Style="{StaticResource TitleTextBlockStyle}" 
                                                   TextWrapping="Wrap"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"/>
                                            <TextBlock x:Uid="NoResultTip2"
                                                   Style="{StaticResource TitleTextBlockStyle}" 
                                                   TextWrapping="Wrap"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"/>
                                            <TextBlock x:Uid="NoResultTip3"
                                                   Style="{StaticResource TitleTextBlockStyle}" 
                                                   TextWrapping="Wrap"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <ItemsRepeater ItemsSource="{x:Bind Wallpapers}" 
                                               Margin="8,0,8,0"
                                               x:Name="WallpapersRepeater"
                                               ContextFlyout="{StaticResource WallpaperContextMenu}">
                                            <ItemsRepeater.Layout>
                                                <UniformGridLayout
                                                    MinItemWidth="{x:Bind ViewModel.PapersControl.WallpaperListMinWidth, Mode=OneWay}"
                                                    MinColumnSpacing="10" 
                                                    MinRowSpacing="10" 
                                                    ItemsStretch="Fill" 
                                                    Orientation="Horizontal"/>
                                            </ItemsRepeater.Layout>

                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:WallpaperItem">
                                                    <Grid x:Name="ItemContainer">
                                                        <Grid.Resources>
                                                            <ThemeShadow x:Name="SharedShadow"/>
                                                        </Grid.Resources>
                                                        <ProgressRing IsActive="True" Background="Transparent"/>
                                                        <Grid x:Name="ShadowCastGrid" Background="Transparent"/>
                                                        <Grid CornerRadius="8"
                                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                              PointerEntered="Item_PointerEntered"
                                                              PointerExited="Item_PointerExited"
                                                              PointerReleased="Item_PointerReleased"
                                                              PointerPressed="Item_PointerPressed"
                                                              RenderTransformOrigin="0.5,0.5"
                                                              x:Name="ItemRootGrid"
                                                              DataContext="{x:Bind}"
                                                              Translation="0,0,64"
                                                              Loaded="ShadowRect_Loaded"
                                                              ContextFlyout="{StaticResource WallpaperContextMenu}"
                                                              RightTapped="WallpaperItem_RightTapped">
                                                            <Viewbox Stretch="Uniform" VerticalAlignment="Top">
                                                                <Canvas Width="100" Height="100"/>
                                                            </Viewbox>

                                                            <Image Stretch="UniformToFill">
                                                                <Image.Source>
                                                                    <BitmapImage UriSource="{x:Bind Preview}" 
                                                                         AutoPlay="{Binding DataContext.ViewModel.PapersControl.AutoPlayGif, ElementName=PageRoot, Mode=OneWay}"/>
                                                                </Image.Source>
                                                            </Image>

                                                            <Grid VerticalAlignment="Bottom" Height="45">
                                                                <Grid.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                                        <GradientStop Color="#CC000000" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Grid.Background>
                                                                <TextBlock Text="{x:Bind Title}" 
                                                                           Foreground="White" 
                                                                           FontSize="12" 
                                                                           VerticalAlignment="Bottom"
                                                                           Margin="10,0,10,8" 
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                            <Border HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    BorderBrush="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    CornerRadius="0,0,0,10"
                                                                    MinWidth="50"
                                                                    MinHeight="20"
                                                                    Padding="4"
                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    Visibility="{Binding DataContext.ViewModel.PapersControl.TagDisplayVisibility, ElementName=PageRoot, Mode=OneWay}"
                                                                    x:Name="TagDisplayBorder">
                                                                <TextBlock Text="{x:Bind Converter={StaticResource PapersTagContentChoose}}"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <CheckBox x:Name="SelectionCheckBox"
                                                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                      Opacity="{x:Bind CheckBoxOpacity, Mode=OneWay}"
                                                                      VerticalAlignment="Top"
                                                                      HorizontalAlignment="Left"
                                                                      Margin="10,8,0,0"
                                                                      Click="SelectionCheckBox_Click"
                                                                      Background="Transparent"
                                                                      CornerRadius="6"
                                                                      MinWidth="0" MinHeight="0" Padding="0" Width="24" Height="24"
                                                                      UseLayoutRounding="True"
                                                                      Content="{x:Null}" 
                                                                      HorizontalContentAlignment="Center"
                                                                      VerticalContentAlignment="Center">
                                                                <CheckBox.Resources>
                                                                    <!-- 未选中状态 -->
                                                                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUnchecked" 
                                                                            ResourceKey="SystemControlBackgroundChromeWhiteBrush" />
                                                                    <StaticResource x:Key="CheckBoxCheckBackgroundFillUncheckedPointerOver" 
                                                                            ResourceKey="SystemControlBackgroundChromeWhiteBrush" />
                                                                </CheckBox.Resources>
                                                            </CheckBox>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </ScrollView>
                                <AnnotatedScrollBar x:Name="Papers_AnnotatedScrollBarControl"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Stretch"
                                                    MaxWidth="10"
                                                    Margin="0,0,8,0"
                                                    Visibility="{x:Bind ViewModel.PapersControl.IsAnnotatedScrollBarEnabled, Mode=OneWay}"
                                                    DetailLabelRequested="Papers_AnnotatedScrollBarControl_DetailLabelRequested"/>
                            </Grid>
                        </SplitView.Content>
                    </SplitView>
                </Grid>
            </SplitView.Content>
        </SplitView>

        <Grid Grid.Row="2" MinWidth="300" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <FontIcon Glyph="&#xE74E;" Margin="15,0,0,0"/>
                <TextBlock x:Uid="ExportDirectory" Margin="4,0,0,0" VerticalAlignment="Center"/>
                <Button Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="0,5,0,0"
                        Command="{x:Bind ViewModel.AutoDetectDownloadPathCommand}">
                    <Button.Content>
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                    </Button.Content>
                </Button>
            </StackPanel>
            <TextBox Grid.Column="1" x:Uid="PapersBottomTextBox" Text="{x:Bind ViewModel.DownloadPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
            <StackPanel VerticalAlignment="Center" Grid.Column="2" Orientation="Horizontal">
                <Button Margin="0,0,0,0" x:Uid="SelectFolder" Command="{x:Bind ViewModel.BrowseFolderCommand}" CommandParameter="DownloadPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                <Button Margin="4,0,8,0" x:Uid="OpenFolder" Command="{x:Bind ViewModel.OpenFolderCommand}" CommandParameter="DownloadPath" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="ScanOverlay"
              Visibility="Collapsed"
              Grid.RowSpan="3"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing x:Name="BackgroundProgressRing" Width="72" Height="72" IsActive="True"/>
                <TextBlock x:Uid="ScanningTip" Style="{ThemeResource DisplayTextBlockStyle}"  FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
